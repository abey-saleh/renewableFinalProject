%% ========================================================================
%  4) SOLAR GEOMETRY
%  This block is provided.
%% ========================================================================
doy   = ceil((1:N)'/24);
delta = 23.45 .* sind((360/365) .* (284 + doy));
omega = 15 .* (t_solar - 12);

cos_tz = sind(phi).*sind(delta) + cosd(phi).*cosd(delta).*cosd(omega);
cos_tz = max(-1, min(1, cos_tz));
daylight = cos_tz > 0;

% Cosine of incidence angle for south-facing surface
cos_ti = ...
    sind(delta).*sind(phi).*cosd(beta_deg) ...
  - sind(delta).*cosd(phi).*sind(beta_deg) ...
  + cosd(delta).*cosd(phi).*cosd(beta_deg).*cosd(omega) ...
  + cosd(delta).*sind(phi).*sind(beta_deg).*cosd(omega);


