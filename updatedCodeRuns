%% ========================================================================
%  9) MAIN DAY-AHEAD SIMULATION LOOP
%
%  For each:
%    forecasting method
%    pricing scheme
%    season
%
%  do the following:
%    - select the prediction week
%    - for each day in that week:
%         * use the PREVIOUS 7 DAYS as forecasting history
%         * forecast the next 24 hours
%         * compute forecasted PV
%         * schedule battery using forecasted PV
%         * evaluate electricity cost
%% ========================================================================

for i = 1:length(forecasters)
    for j = 1:length(schemes)
        for k = 1:length(seasons)

            forecast_name = forecasters{i};
            scheme_name   = schemes{j};
            season_name   = seasons{k};

            % ---------------------------------------------------------
            % Select the prediction week
            %
            % Summer evaluation:
            %   first week of July
            %
            % Winter evaluation:
            %   first week of February
            %
            % For each day in the prediction week, the previous 168 hours
            % are used as the historical input to the forecasting tool.
            % This means:
            %   - for July 1, the historical data comes from the last week
            %     of June
            %   - for February 1, the historical data comes from the last
            %     week of January
            % ---------------------------------------------------------
            if strcmp(season_name, 'summer')
                idx_pred_week = find(month(time) == 7 & day(time) <= 7);
            elseif strcmp(season_name, 'winter')
                idx_pred_week = find(month(time) == 2 & day(time) <= 7);
            else
                error('Unknown season.');
            end

            if length(idx_pred_week) ~= 168
                error('Prediction week must contain exactly 168 hourly points.');
            end

            % ---------------------------------------------------------
            % Day-ahead operation over 7 days
            % ---------------------------------------------------------
            for d = 1:7

                % Current 24-hour operating day
                idx_day = idx_pred_week((d-1)*24 + (1:24));

                % Previous 168 hours = forecasting history
                idx_hist = (idx_day(1)-168):(idx_day(1)-1);

                % Safety check
                if idx_hist(1) < 1
                    error('Not enough historical data before day %d.', d);
                end

                % -----------------------------------------------------
                % Historical weather data for the forecasting tool
                % -----------------------------------------------------
                % T_past7 = ; %TODO
                T_past7 = table();
                T_past7.GHI    = GHI(idx_hist);
                T_past7.DNI    = DNI(idx_hist);
                T_past7.DHI    = DHI(idx_hist);
                T_past7.Tamb   = Tamb(idx_hist);
                T_past7.albedo = alb(idx_hist);
                T_past7.wind   = vwind(idx_hist);

                % -----------------------------------------------------
                % Generate 24-hour weather forecast
                % -----------------------------------------------------
                [GHI_f, DNI_f, DHI_f, Tamb_f, albedo_f, wind_f] = ...
                    forecast_weather(T_past7, forecast_name);

                % -----------------------------------------------------
                % TODO: Compute forecasted PV generation for this day
                %
                % Reuse your Homework 2 code and your chosen PV design.
                % This output must be a [24 x 1] AC power vector in kW.
                %
                % Suggested workflow:
                %   1) Determine the 24 timestamps for idx_day
                %   2) Compute solar geometry for those 24 hours
                %   3) Compute GPOA from forecasted weather
                %   4) Compute cell temperature
                %   5) Compute PV DC/AC power
                %
                % Example placeholder:
                % P_pv_forecast = ... ;
                % -----------------------------------------------------
                time_day  = time(idx_day);
                doy_f     = day(time_day, 'dayofyear');
                delta_f   = 23.45 .* sind((360/365) .* (284 + doy_f));
 
                % t_solar for forecast hours: use actual solar time from weather data
                t_solar_f = t_solar(idx_day);
                omega_f   = 15 .* (t_solar_f - 12);
 
                cos_tz_f = sind(phi).*sind(delta_f) + cosd(phi).*cosd(delta_f).*cosd(omega_f);
                cos_tz_f = max(-1, min(1, cos_tz_f));
                daylight_f = cos_tz_f > 0;
 
                cos_ti_f = ...
                    sind(delta_f).*sind(phi).*cosd(beta_deg) ...
                  - sind(delta_f).*cosd(phi).*sind(beta_deg) ...
                  + cosd(delta_f).*cosd(phi).*cosd(beta_deg).*cosd(omega_f) ...
                  + cosd(delta_f).*sind(phi).*sind(beta_deg).*cosd(omega_f);
 
                % 2) GPOA from forecasted weather
                G_beam_f = DNI_f .* max(0, cos_ti_f);
                G_diff_f = DHI_f .* (1 + cosd(beta_deg)) / 2;
                G_refl_f = GHI_f .* albedo_f .* (1 - cosd(beta_deg)) / 2;
                GPOA_f   = max(0, G_beam_f + G_diff_f + G_refl_f);
 
                % 3) Cell temperature (forecasted)
                Tcell_f = Tamb_f + ((NOCT - 20) / 800) .* GPOA_f - kv .* wind_f;
 
                % 4) PV DC power (forecasted)
                P_dc_f = Ns .* Np .* (P_mod_STC / 1000) .* GPOA_f .* ...
                         (1 + (gammaT/100) .* (Tcell_f - 25)) / 1000;
                P_dc_f(~daylight_f) = 0;
                P_dc_f = max(0, P_dc_f);
 
                % 5) AC PV forecast [kW]
                P_pv_forecast = P_dc_f .* eta_inv;


                % -----------------------------------------------------
                % Actual PV generation for the same day
                % -----------------------------------------------------
                % TODO: extract or compute actual PV generation for idx_day
                % -----------------------------------------------------
                P_pv_actual = P_pv_year(idx_day);

                % -----------------------------------------------------
                % Demand and prices for the current operating day
                % -----------------------------------------------------
                P_demand  = demand_year(idx_day);
                TOU_price = price_year.(scheme_name)(idx_day);

% -----------------------------------------------------
                % Day-ahead battery scheduling
                % -----------------------------------------------------
                if d == 1
                    E_ini = E_ini_default;
                else
                    E_ini = E(end);
                end
                
                [scheduled_cost, P_grid_sched, P_ch, P_dis, E] = ...
                    optimize_battery(P_pv_forecast, P_demand, TOU_price, E_ini);

                % -----------------------------------------------------
                % Baseline cost calculations for No PV, PV only, PV + battery
                % -----------------------------------------------------
                daily_cost_noPV = TOU_price' * P_demand;
 
                P_grid_PVonly   = max(0, P_demand - P_pv_actual);
                daily_cost_PVonly = TOU_price' * P_grid_PVonly;
 
                P_grid_actual   = max(0, P_demand - P_pv_actual + P_ch - P_dis);
                daily_cost_actual = TOU_price' * P_grid_actual;

                % -----------------------------------------------------
                % Store results     
                % -----------------------------------------------------
                Results.(forecast_name).(scheme_name).(season_name).daily_cost(d) = scheduled_cost; 
                Results.(forecast_name).(scheme_name).(season_name).daily_cost_actual(d) = daily_cost_actual; 
                Results.(forecast_name).(scheme_name).(season_name).daily_cost_noPV(d)   = daily_cost_noPV; 
                Results.(forecast_name).(scheme_name).(season_name).daily_cost_PVonly(d) = daily_cost_PVonly; 

                Results.(forecast_name).(scheme_name).(season_name).P_grid{d} = P_grid_sched;
                Results.(forecast_name).(scheme_name).(season_name).P_ch{d}          = P_ch;
                Results.(forecast_name).(scheme_name).(season_name).P_dis{d}         = P_dis;
                Results.(forecast_name).(scheme_name).(season_name).E{d}             = E;
                Results.(forecast_name).(scheme_name).(season_name).P_pv_forecast{d} = P_pv_forecast;
                Results.(forecast_name).(scheme_name).(season_name).P_pv_actual{d}   = P_pv_actual;
                Results.(forecast_name).(scheme_name).(season_name).P_demand{d}      = P_demand;
                Results.(forecast_name).(scheme_name).(season_name).TOU_price{d}     = TOU_price;
                Results.(forecast_name).(scheme_name).(season_name).idx_day{d}       = idx_day;
            end
        end
    end
end

    
