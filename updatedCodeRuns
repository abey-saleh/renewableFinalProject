function T_clean = format_sam_weather(filename)
%FORMAT_SAM_WEATHER Read and clean SAM weather data exported from NREL/SAM.

    opts = detectImportOptions(filename);
    opts.DataLines = [4, Inf];
    opts.VariableNamesLine = 3;

    T_raw = readtable(filename, opts);

    T_clean = table();
    T_clean.t_solar = T_raw.Hour + (T_raw.Minute / 60);
    T_clean.DNI     = T_raw.DNI;
    T_clean.DHI     = T_raw.DHI;
    T_clean.GHI     = T_raw.GHI;
    T_clean.Tamb    = T_raw.Temperature;
    T_clean.albedo  = T_raw.SurfaceAlbedo;
    T_clean.wind    = T_raw.WindSpeed;
end


function [GHI_f, DNI_f, DHI_f, Tamb_f, albedo_f, wind_f] = forecast_weather(T_past7, method)
%FORECAST_WEATHER Predict the next 24 hours from the previous 7 days.
%
% Inputs:
%   T_past7 : table with 168 rows and columns
%             GHI, DNI, DHI, Tamb, albedo, wind
%   method  : 'persistence', 'moving_avg', or 'linear'
%
% Outputs:
%   Each output is a [24 x 1] forecast vector.

    variables = {'GHI', 'DNI', 'DHI', 'Tamb', 'albedo', 'wind'};
    results = cell(1, 6);

    for i = 1:6
        var_name = variables{i};
        data = T_past7.(var_name);
        data_fcst = zeros(24, 1);

        if strcmp(method, 'persistence')
            data_fcst = data(145:168);

        elseif strcmp(method, 'moving_avg')
            d1 = data(145:168);
            d2 = data(121:144);
            d3 = data(97:120);
            data_fcst = (d1 + d2 + d3) / 3;

        elseif strcmp(method, 'linear')
            x_days = (1:7)';
            x_target = 8;

            for h = 1:24
                idx_h = h:24:168;
                p = polyfit(x_days, data(idx_h), 1);
                data_fcst(h) = polyval(p, x_target);
            end

            if ~strcmp(var_name, 'Tamb')
                data_fcst = max(0, data_fcst);
            end

        else
            error('Method not valid. Use: persistence, moving_avg, or linear');
        end

        results{i} = data_fcst;
    end

    GHI_f    = results{1};
    DNI_f    = results{2};
    DHI_f    = results{3};
    Tamb_f   = results{4};
    albedo_f = results{5};
    wind_f   = results{6};
end


function [scheduled_cost, P_grid, P_ch, P_dis, E] = optimize_battery(P_pv, P_demand, TOU_price, E_ini)
%OPTIMIZE_BATTERY Compute the optimal 24-hour battery schedule.
%
% Inputs:
%   P_pv      : [24 x 1] forecasted PV generation [kW]
%   P_demand  : [24 x 1] demand [kW]
%   TOU_price : [24 x 1] electricity price [$/kWh]
%   E_ini     : initial battery energy [kWh]
%
% Outputs:
%   scheduled_cost : daily electricity cost [$]
%   P_grid         : [24 x 1] grid import [kW]
%   P_ch           : [24 x 1] battery charging power [kW]
%   P_dis          : [24 x 1] battery discharging power [kW]
%   E              : [24 x 1] battery energy [kWh]

    % Battery parameters
    E_max    = 13.5;           % kWh
    P_max    = 4.5;            % kW
    E_min    = 0.20 * E_max;   % kWh
    E_target = 0.50 * E_max;   % kWh
    RTE      = 0.95;

    eta_c = sqrt(RTE);
    eta_d = sqrt(RTE);

    N = 24;

    if length(P_pv) ~= N || length(P_demand) ~= N || length(TOU_price) ~= N
        error('P_pv, P_demand, and TOU_price must each contain 24 entries.');
    end

    P_pv      = P_pv(:);
    P_demand  = P_demand(:);
    TOU_price = TOU_price(:);

    cvx_begin quiet
        variables P_grid(N) P_ch(N) P_dis(N) E(N)

        minimize(TOU_price' * P_grid)

        subject to
            % Power balance
            P_grid == P_demand - P_pv + P_ch - P_dis;

            % No selling back to the grid
            P_grid >= 0;

            % Power limits
            0 <= P_ch  <= P_max;
            0 <= P_dis <= P_max;

            % Energy limits
            E_min <= E <= E_max;

            % Energy dynamics
            E(1) == E_ini + eta_c * P_ch(1) - (1 / eta_d) * P_dis(1);

            for t = 2:N
                E(t) == E(t-1) + eta_c * P_ch(t) - (1 / eta_d) * P_dis(t);
            end

            % End-of-day minimum energy
            E(N) >= E_target;
    cvx_end

    scheduled_cost = cvx_optval;
end


function price_year = build_yearly_price_vectors(N)
%BUILD_YEARLY_PRICE_VECTORS Generate full-year hourly prices for each tariff.

    prices = struct();

    % Flat rate
    prices.flat_rate.summer = 0.14 * ones(24,1);
    prices.flat_rate.winter = 0.14 * ones(24,1);

    % Current TOU
    prices.current_TOU.summer = [ ...
        0.11*ones(17,1);
        0.28*ones(4,1);
        0.11*ones(3,1)
    ];

    prices.current_TOU.winter = [ ...
        0.10*ones(17,1);
        0.22*ones(4,1);
        0.10*ones(3,1)
    ];

    % Three-tier TOU: summer
    prices.three_tier_TOU.summer = [ ...
        0.10*ones(9,1);
        0.15*ones(5,1);
        0.25*ones(4,1);
        0.15*ones(3,1);
        0.10*ones(3,1)
    ];

    % Three-tier TOU: winter
    prices.three_tier_TOU.winter = [ ...
        0.09*ones(9,1);
        0.13*ones(8,1);
        0.20*ones(2,1);
        0.13*ones(2,1);
        0.09*ones(3,1)
    ];

    time = datetime(2024,1,1,0,0,0) + hours(0:N-1)';
    schemes = {'flat_rate','current_TOU','three_tier_TOU'};

    price_year = struct();
    for j = 1:length(schemes)
        price_year.(schemes{j}) = zeros(N,1);
    end

    for t = 1:N
        if month(time(t)) >= 6 && month(time(t)) <= 9
            season_name = 'summer';
        else
            season_name = 'winter';
        end

        h = hour(time(t)) + 1;

        for j = 1:length(schemes)
            scheme_name = schemes{j};
            price_year.(scheme_name)(t) = prices.(scheme_name).(season_name)(h);
        end
    end
end
