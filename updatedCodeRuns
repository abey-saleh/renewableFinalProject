% -------------------------
% Plane-of-array irradiance
% -------------------------
rho = alb;  % Ground reflectance = albedo
 
% Direct (beam) component on tilted surface
G_beam_tilted = DNI .* max(0, cos_ti);
 
% Diffuse (sky) component — isotropic model
G_diff_tilted = DHI .* (1 + cosd(beta_deg)) / 2;
 
% Ground-reflected component
G_refl_tilted = GHI .* rho .* (1 - cosd(beta_deg)) / 2;
 
% Total plane-of-array irradiance
GPOA = G_beam_tilted + G_diff_tilted + G_refl_tilted;
GPOA = max(0, GPOA);
 
% -------------------------
% Cell temperature
% -------------------------
% NOCT-based model: Tcell = Tamb + (NOCT - 20)/800 * GPOA - kv * vwind
Tcell = Tamb + ((NOCT - 20) / 800) .* GPOA - kv .* vwind;
 
% -------------------------
% Module / string voltage
% -------------------------
Vmp_mod    = Vmp_STC + Vmp_Tcoef .* (Tcell - 25);
Vmp_string = Ns .* Vmp_mod;
 
% -------------------------
% Yearly AC PV output [kW]
% -------------------------
% Temperature-corrected power factor
P_dc_per_mod = (P_mod_STC / 1000) .* GPOA .* (1 + (gammaT/100) .* (Tcell - 25));  % [W -> kW factor applied below]
% Convert W to kW and multiply by number of modules
P_dc = Ns .* Np .* P_dc_per_mod / 1000;  % [kW]  (P_mod_STC is in W, GPOA in W/m^2 relative to 1000 W/m^2)
 
% Zero out night hours
P_dc(~daylight) = 0;
P_dc = max(0, P_dc);
 
% Apply inverter efficiency to get AC output
